# Choose one provider and add its key

# Option 1 — Auto format (default, no key needed)
CONTEXTBRIDGE_PROVIDER=auto-format

# Option 2 — Gemini free tier
# CONTEXTBRIDGE_PROVIDER=gemini
# GEMINI_API_KEY=your-key-here

# Option 3 — Ollama local (no key needed)
# CONTEXTBRIDGE_PROVIDER=ollama
# OLLAMA_MODEL=llama3

# Option 4 — Anthropic
# CONTEXTBRIDGE_PROVIDER=anthropic
# ANTHROPIC_API_KEY=sk-ant-...

# Option 5 — OpenAI
# CONTEXTBRIDGE_PROVIDER=openai
# OPENAI_API_KEY=sk-...

# Debug mode (optional)
# CONTEXTBRIDGE_DEBUG=false
